# =============================================================================
# goloop Docker Compose 配置示例
# 复制为 .env 并填入真实值
# =============================================================================

# -----------------------------------------------------------------------------
# 必填配置
# -----------------------------------------------------------------------------

# JWT 签名密钥（用于管理员登录，至少32字符）
JWT_SECRET=your-jwt-signing-secret-at-least-32-chars-long

# Admin UI 鉴权密码（至少16字符）
ADMIN_PASSWORD=your-admin-password-at-least-16-chars

# PostgreSQL 密码（docker-compose 中使用）
POSTGRES_PASSWORD=goloop123

# -----------------------------------------------------------------------------
# 数据库和缓存配置（Docker Compose 自动配置，无需修改）
# -----------------------------------------------------------------------------

# PostgreSQL 连接 - docker-compose 会自动设置
# DATABASE_URL=postgresql://goloop:goloop123@postgres:5432/goloop?sslmode=disable

# Redis 连接 - docker-compose 会自动设置
# REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# 可选配置
# -----------------------------------------------------------------------------

# Redis 是否启用（默认 true，强烈建议保持启用）
# REDIS_ENABLED=true

# API Key 缓存 TTL（默认 5m）
# REDIS_APIKEY_CACHE_TTL=5m

# JWT Token 有效期（默认 24h）
# JWT_EXPIRY=24h

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------

# 监听端口（默认 8080）
# SERVER_PORT=8080

# HTTP 读超时（默认 1300s，约 21.7 分钟）
# SERVER_READ_TIMEOUT=1300s

# HTTP 写超时（默认 1300s，约 21.7 分钟）
# SERVER_WRITE_TIMEOUT=1300s

# 请求体最大大小（单位 MB，默认 50）
# SERVER_MAX_REQUEST_BODY_MB=50

# -----------------------------------------------------------------------------
# 存储配置（图片落地）
# -----------------------------------------------------------------------------

# 存储类型：local（默认）
# STORAGE_TYPE=local

# 本地存储路径（默认 /tmp/images）
# STORAGE_LOCAL_PATH=/tmp/images

# 图片访问 Base URL（需要修改为你的实际域名）
STORAGE_BASE_URL=http://localhost:8080/images

# 下载生成结果图片的超时（默认 120s）
# STORAGE_DOWNLOAD_TIMEOUT=120s

# 图片最大大小（单位 MB，默认 30）
# STORAGE_MAX_IMAGE_MB=30

# -----------------------------------------------------------------------------
# 健康检测配置
# -----------------------------------------------------------------------------

# 主动探测间隔（默认 30s）
# HEALTH_PROBE_INTERVAL=30s

# 单次探测超时（默认 5s）
# HEALTH_PROBE_TIMEOUT=5s

# 连续成功几次后恢复健康（默认 2）
# HEALTH_RECOVERY_THRESHOLD=2

# 硬停止渠道距上次失败多久后自动恢复到 50% 健康度（默认 30m）
# HEALTH_RECOVERY_INTERVAL=30m

# -----------------------------------------------------------------------------
# 限流配置（可选）
# -----------------------------------------------------------------------------

# 每秒请求数限制（默认 0 表示不限流）
# RATELIMIT_RPS=0

# 突发容量（默认 10）
# RATELIMIT_BURST=10

# =============================================================================
# Docker Compose 说明
# =============================================================================
#
# 使用 Docker Compose 启动：
# 1. 复制此文件为 .env
# 2. 修改必填配置（JWT_SECRET, ADMIN_PASSWORD, POSTGRES_PASSWORD）
# 3. 运行：docker-compose up -d
# 4. 访问：http://localhost:8080/admin/ui/
#
# 服务包括：
# - postgres: PostgreSQL 16 数据库（端口 5432）
# - redis: Redis 7 缓存（端口 6379）
# - goloop: 主应用服务（端口 8080）
#
# 数据持久化：
# - goloop-postgres-data: PostgreSQL 数据
# - goloop-redis-data: Redis 数据
# - goloop-images: 生成的图片文件
#
# 健康检查：
# - 服务会自动等待 PostgreSQL 和 Redis 就绪后才启动
# - 使用 depends_on 和 healthcheck 确保启动顺序
#
# =============================================================================
