# --- 必填 ---
JWT_SECRET=your-jwt-signing-secret         # JWT 签名密钥
ADMIN_PASSWORD=超级复杂的密码至少16字符      # Admin API 鉴权密码

# --- 渠道配置（新格式，推荐） ---
CHANNELS=kieai                              # 逗号分隔的渠道列表
CHANNEL_KIEAI_TYPE=kieai
CHANNEL_KIEAI_BASE_URL=https://api.kie.ai
CHANNEL_KIEAI_TIMEOUT=120s
CHANNEL_KIEAI_ACCOUNTS=key1:50,key2:30,key3:20    # apikey:weight

# --- 或旧格式（向后兼容） ---
KIEAI_BASE_URL=https://api.kie.ai
KIEAI_KEY_1=xxx
KIEAI_WEIGHT_1=50

# --- 可选 ---
SERVER_PORT=8080
STORAGE_BASE_URL=http://localhost:8080/images