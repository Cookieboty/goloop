# =============================================================================
# goloop 配置示例
# 复制为 .env 并填入真实值
# =============================================================================

# -----------------------------------------------------------------------------
# 必填
# -----------------------------------------------------------------------------
# JWT 签名密钥
JWT_SECRET=your-jwt-signing-secret-at-least-32-chars
# Admin UI 鉴权密码（≥16字符）
ADMIN_PASSWORD=超级复杂的密码至少16字符

# -----------------------------------------------------------------------------
# 渠道配置 — 新格式（推荐，支持多渠道）
#
# 路由规则：所有渠道都能服务所有模型，按权重降序优先尝试（权重越高越优先）。
# 若高权重渠道失败或被熔断，自动降级到下一个渠道，直到全部失败返回 503。
# -----------------------------------------------------------------------------
# 逗号分隔的渠道名称列表
CHANNELS=kieai,subrouter

# kieai 渠道（高权重 = 优先尝试）
# 渠道类型
CHANNEL_KIEAI_TYPE=kieai
# 渠道 API 地址
CHANNEL_KIEAI_BASE_URL=https://api.kie.ai
# 渠道路由权重（高权重优先）
CHANNEL_KIEAI_WEIGHT=100
# 账号列表，格式 apikey:weight
CHANNEL_KIEAI_ACCOUNTS=key1:50,key2:30,key3:20
# 单次请求超时（默认 120s）
CHANNEL_KIEAI_TIMEOUT=120s
# 轮询初始间隔（默认 2s）
CHANNEL_KIEAI_INITIAL_INTERVAL=2s
# 轮询最大间隔（默认 10s）
CHANNEL_KIEAI_MAX_INTERVAL=10s
# 任务最长等待时间（默认 120s）
CHANNEL_KIEAI_MAX_WAIT_TIME=120s
# 连续失败重试次数（默认 3）
CHANNEL_KIEAI_RETRY_ATTEMPTS=3

# subrouter 渠道（低权重 = 备选降级，OpenAI 兼容 API）
# 使用通用 openai 类型，"subrouter" 类型名保持向后兼容
CHANNEL_SUBROUTER_TYPE=openai
# OpenAI 兼容 API 根地址（只填域名，不含路径；代码会自动拼接 /v1/chat/completions）
CHANNEL_SUBROUTER_BASE_URL=https://your-openai-compatible-api.com
# 权重低于 kieai，作为降级备选
CHANNEL_SUBROUTER_WEIGHT=50
# 账号列表，格式 apikey:weight
CHANNEL_SUBROUTER_ACCOUNTS=sk-key1:100,sk-key2:50
# 同步请求超时（默认 60s）
CHANNEL_SUBROUTER_TIMEOUT=60s
# 可选，探活使用的模型（默认 gpt-4o-mini）
CHANNEL_SUBROUTER_PROBE_MODEL=gpt-4o-mini

# 零代码接入新 OpenAI 兼容渠道示例（只需修改 .env，无需改代码）
# CHANNELS=kieai,subrouter,openrouter,deepseek
#
# CHANNEL_OPENROUTER_TYPE=openai
# CHANNEL_OPENROUTER_BASE_URL=https://openrouter.ai/api
# CHANNEL_OPENROUTER_WEIGHT=30
# CHANNEL_OPENROUTER_ACCOUNTS=sk-or-xxx:100
# CHANNEL_OPENROUTER_PROBE_MODEL=meta-llama/llama-3-8b-instruct
#
# CHANNEL_DEEPSEEK_TYPE=openai
# CHANNEL_DEEPSEEK_BASE_URL=https://api.deepseek.com
# CHANNEL_DEEPSEEK_WEIGHT=20
# CHANNEL_DEEPSEEK_ACCOUNTS=sk-ds-xxx:100
# CHANNEL_DEEPSEEK_PROBE_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# 渠道配置 — 旧格式（向后兼容，仅单 kieai 渠道）
# -----------------------------------------------------------------------------
# KIEAI_BASE_URL=https://api.kie.ai
# KIEAI_WEIGHT=100
# KIEAI_KEY_1=your-api-key-1
# KIEAI_WEIGHT_1=50
# KIEAI_KEY_2=your-api-key-2
# KIEAI_WEIGHT_2=30
# KIEAI_TIMEOUT=120s

# -----------------------------------------------------------------------------
# 服务器
# -----------------------------------------------------------------------------
# 监听端口（默认 8080）
SERVER_PORT=8080
# HTTP 读超时（默认 130s）
SERVER_READ_TIMEOUT=130s
# HTTP 写超时（默认 130s）
SERVER_WRITE_TIMEOUT=130s

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Token 有效期（默认 24h）
JWT_EXPIRY=24h

# -----------------------------------------------------------------------------
# 存储（图片落地）
# -----------------------------------------------------------------------------
# 存储类型：local（默认）
STORAGE_TYPE=local
# 本地存储路径（默认 /tmp/images）
STORAGE_LOCAL_PATH=/tmp/images
# 图片访问 Base URL
STORAGE_BASE_URL=http://localhost:8080/images

# -----------------------------------------------------------------------------
# 健康检测
# -----------------------------------------------------------------------------
# 主动探测间隔（默认 30s）
HEALTH_PROBE_INTERVAL=30s
# 单次探测超时（默认 5s）
HEALTH_PROBE_TIMEOUT=5s
# 连续成功几次后恢复健康（默认 2）
HEALTH_RECOVERY_THRESHOLD=2

# -----------------------------------------------------------------------------
# 模型映射（覆盖内置默认值）
# -----------------------------------------------------------------------------
# gemini-3.1-flash-image-preview 映射的 KIE.AI 模型
MODEL_NANO_BANANA_2=nano-banana-2
# gemini-3-pro-image-preview 映射的 KIE.AI 模型
MODEL_NANO_BANANA_PRO=nano-banana-pro
# gemini-2.5-flash-image 映射的 KIE.AI 模型
MODEL_GOOGLE_NANO_BANANA=google/nano-banana
