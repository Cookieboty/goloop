# =============================================================================
# goloop 配置示例
# 复制为 .env 并填入真实值
# =============================================================================

# -----------------------------------------------------------------------------
# 必填配置
# -----------------------------------------------------------------------------

# JWT 签名密钥（用于管理员登录，至少32字符）
JWT_SECRET=your-jwt-signing-secret-at-least-32-chars-long

# Admin UI 鉴权密码（至少16字符）
ADMIN_PASSWORD=your-admin-password-at-least-16-chars

# PostgreSQL 数据库连接（所有渠道配置存储在数据库中）
DATABASE_URL=postgresql://user:password@localhost:5432/goloop?sslmode=disable

# Redis 连接（用于 API Key 验证缓存，这是架构的关键组件）
# 建议使用 Redis Sentinel 或 Cluster 保证高可用
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# 可选配置
# -----------------------------------------------------------------------------

# Redis 是否启用（默认 true，强烈建议保持启用）
# REDIS_ENABLED=true

# API Key 缓存 TTL（默认 5m）
# REDIS_APIKEY_CACHE_TTL=5m

# JWT Token 有效期（默认 24h）
# JWT_EXPIRY=24h

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------

# 监听端口（默认 8080）
# SERVER_PORT=8080

# HTTP 读超时（默认 1300s，约 21.7 分钟）
# SERVER_READ_TIMEOUT=1300s

# HTTP 写超时（默认 1300s，约 21.7 分钟）
# SERVER_WRITE_TIMEOUT=1300s

# 请求体最大大小（单位 MB，默认 50）
# SERVER_MAX_REQUEST_BODY_MB=50

# -----------------------------------------------------------------------------
# 存储配置（图片落地）
# -----------------------------------------------------------------------------

# 存储类型：local（默认）
# STORAGE_TYPE=local

# 本地存储路径（默认 /tmp/images）
# STORAGE_LOCAL_PATH=/tmp/images

# 图片访问 Base URL
# STORAGE_BASE_URL=http://localhost:8080/images

# 下载生成结果图片的超时（默认 120s）
# STORAGE_DOWNLOAD_TIMEOUT=120s

# 图片最大大小（单位 MB，默认 30）
# STORAGE_MAX_IMAGE_MB=30

# -----------------------------------------------------------------------------
# 健康检测配置
# -----------------------------------------------------------------------------

# 主动探测间隔（默认 30s）
# HEALTH_PROBE_INTERVAL=30s

# 单次探测超时（默认 5s）
# HEALTH_PROBE_TIMEOUT=5s

# 连续成功几次后恢复健康（默认 2）
# HEALTH_RECOVERY_THRESHOLD=2

# 硬停止渠道距上次失败多久后自动恢复到 50% 健康度（默认 30m）
# HEALTH_RECOVERY_INTERVAL=30m

# -----------------------------------------------------------------------------
# 限流配置（可选）
# -----------------------------------------------------------------------------

# 每秒请求数限制（默认 0 表示不限流）
# RATELIMIT_RPS=0

# 突发容量（默认 10）
# RATELIMIT_BURST=10

# =============================================================================
# 渠道配置说明
# =============================================================================
#
# 从此版本开始，所有渠道配置已迁移到数据库中，通过 Admin UI 进行管理。
# 不再需要在 .env 文件中配置渠道！
#
# 支持的渠道类型：
# - gemini_callback: 异步轮询方式的 Gemini API（原 kieai）
# - gemini_openai: OpenAI 兼容的 Gemini API（原 subrouter）
# - gemini_original: Google 原生 Gemini API（原 gemini）
# - openai_original: OpenAI 原生 API（原 gpt-image）
# - openai_callback: 异步轮询方式的 OpenAI API（新增）
#
# 通过 Admin UI 可以：
# 1. 创建和管理渠道（名称、类型、Base URL、权重、超时等）
# 2. 管理每个渠道的账号池（API Key、权重、启用/禁用）
# 3. 配置每个渠道的模型映射（源模型 -> 目标模型）
# 4. 颁发和管理客户端 API Key（格式：goloop_xxxxx）
# 5. 查看 API Key 使用统计和日志（最近 30 天）
# 6. 热更新配置（无需重启服务）
#
# 首次启动：
# 1. 确保 PostgreSQL 和 Redis 已运行
# 2. 启动服务：./goloop
# 3. 访问 Admin UI：http://localhost:8080/admin/ui/
# 4. 使用 ADMIN_PASSWORD 登录
# 5. 在 UI 中添加渠道和账号
# 6. 颁发 API Key 供客户端使用
#
# =============================================================================
