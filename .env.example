# =============================================================================
# goloop 配置示例
# 复制为 .env 并填入真实值
# =============================================================================

# -----------------------------------------------------------------------------
# 必填
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-signing-secret-at-least-32-chars   # JWT 签名密钥
ADMIN_PASSWORD=超级复杂的密码至少16字符                  # Admin UI 鉴权密码（≥16字符）

# -----------------------------------------------------------------------------
# 渠道配置 — 新格式（推荐，支持多渠道）
# -----------------------------------------------------------------------------
CHANNELS=kieai                             # 逗号分隔的渠道名称列表，如 kieai,kieai-pro

# kieai 渠道
CHANNEL_KIEAI_TYPE=kieai                   # 渠道类型（目前只支持 kieai）
CHANNEL_KIEAI_BASE_URL=https://api.kie.ai  # 渠道 API 地址
CHANNEL_KIEAI_WEIGHT=100                   # 渠道路由权重（默认 100，多渠道时按比例分流）
CHANNEL_KIEAI_ACCOUNTS=key1:50,key2:30,key3:20  # 账号列表，格式 apikey:weight，weight 默认 100
CHANNEL_KIEAI_TIMEOUT=120s                 # 单次请求超时（默认 120s）
CHANNEL_KIEAI_INITIAL_INTERVAL=2s          # 轮询初始间隔（默认 2s）
CHANNEL_KIEAI_MAX_INTERVAL=10s             # 轮询最大间隔（默认 10s）
CHANNEL_KIEAI_MAX_WAIT_TIME=120s           # 任务最长等待时间（默认 120s）
CHANNEL_KIEAI_RETRY_ATTEMPTS=3             # 连续失败重试次数（默认 3）

# 多渠道示例（取消注释后在 CHANNELS 中加上 kieai-pro）
# CHANNELS=kieai,kieai-pro
# CHANNEL_KIEAI_PRO_TYPE=kieai
# CHANNEL_KIEAI_PRO_BASE_URL=https://api.kie.ai
# CHANNEL_KIEAI_PRO_WEIGHT=50
# CHANNEL_KIEAI_PRO_ACCOUNTS=prokey1:100,prokey2:100

# -----------------------------------------------------------------------------
# 渠道配置 — 旧格式（向后兼容，仅单 kieai 渠道）
# -----------------------------------------------------------------------------
# KIEAI_BASE_URL=https://api.kie.ai
# KIEAI_WEIGHT=100                          # 渠道整体权重（默认 100）
# KIEAI_KEY_1=your-api-key-1
# KIEAI_WEIGHT_1=50                         # 账号权重（默认 100）
# KIEAI_KEY_2=your-api-key-2
# KIEAI_WEIGHT_2=30
# KIEAI_TIMEOUT=120s

# -----------------------------------------------------------------------------
# 服务器
# -----------------------------------------------------------------------------
SERVER_PORT=8080                           # 监听端口（默认 8080）
SERVER_READ_TIMEOUT=130s                   # HTTP 读超时（默认 130s）
SERVER_WRITE_TIMEOUT=130s                  # HTTP 写超时（默认 130s）

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_EXPIRY=24h                             # Token 有效期（默认 24h）

# -----------------------------------------------------------------------------
# 存储（图片落地）
# -----------------------------------------------------------------------------
STORAGE_TYPE=local                         # 存储类型：local（默认）
STORAGE_LOCAL_PATH=/tmp/images             # 本地存储路径（默认 /tmp/images）
STORAGE_BASE_URL=http://localhost:8080/images  # 图片访问 Base URL

# -----------------------------------------------------------------------------
# 健康检测
# -----------------------------------------------------------------------------
HEALTH_PROBE_INTERVAL=30s                  # 主动探测间隔（默认 30s）
HEALTH_PROBE_TIMEOUT=5s                    # 单次探测超时（默认 5s）
HEALTH_RECOVERY_THRESHOLD=2                # 连续成功几次后恢复健康（默认 2）

# -----------------------------------------------------------------------------
# 模型映射（覆盖内置默认值）
# -----------------------------------------------------------------------------
MODEL_NANO_BANANA_2=nano-banana-2          # gemini-3.1-flash-image-preview 映射的 KIE.AI 模型
MODEL_NANO_BANANA_PRO=nano-banana-pro      # gemini-3-pro-image-preview 映射的 KIE.AI 模型
MODEL_GOOGLE_NANO_BANANA=google/nano-banana  # gemini-2.5-flash-image 映射的 KIE.AI 模型
